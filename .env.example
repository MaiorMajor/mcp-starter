VAULT_PATH=/home/you/your-obsidian-vault
MCP_API_KEY=replace-with-openssl-rand-hex-32
JWT_SECRET=replace-with-openssl-rand-hex-32
OAUTH_PASSWORD=your-oauth-password
MCP_BASE_URL=https://your-domain.com
# Optional: comma-separated allowed Origin headers (* = allow all; unset = restrictive default)
# MCP_ALLOWED_ORIGINS=*

# Optional: bootstrap a local OAuth client (exact URIs, comma-separated)
# OAUTH_REDIRECT_URIS=http://127.0.0.1:6274/oauth/callback,https://claude.ai/api/mcp/auth_callback
